# ============================================================
# BACKEND .gitignore  (Spring Boot + Maven)
# ============================================================

# ── Maven build output (always regenerated via mvn build) ────
target/
!.mvn/wrapper/maven-wrapper.jar
!**/src/main/**/target/
!**/src/test/**/target/

# ── Environment & secrets ────────────────────────────────────
.env
.env.local
application-secret.properties
application-local.properties
# Keep application.properties but NOT if it has real secrets
# If your application.properties has DB passwords/JWT secrets,
# add it below and use environment variables instead:
src/main/resources/application.properties

# ── IDE configs ──────────────────────────────────────────────

### IntelliJ IDEA ###
.idea/
*.iws
*.iml
*.ipr

### Eclipse / STS ###
.apt_generated
.classpath
.factorypath
.project
.settings
.springBeans
.sts4-cache

### NetBeans ###
/nbproject/private/
/nbbuild/
/dist/
/nbdist/
/.nb-gradle/
build/
!**/src/main/**/build/
!**/src/test/**/build/

### VS Code ###
.vscode/

# ── OS files ─────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── Logs ────────────────────────────────────────────────────
*.log
logs/

# ── Docker (not needed for source upload) ────────────────────
Dockerfile
docker-compose.yml
docker-compose*.yml
.dockerignore

# ── Compiled class files (inside target, but just in case) ───
*.class

# ── Package files ────────────────────────────────────────────
*.jar
*.war
*.ear
*.nar

# ── Maven wrapper (keep .mvn folder but not OS-specific) ─────
mvnw.cmd
